# Server
PORT=4000
NODE_ENV=production
CORS_ORIGIN=*

# Database (SQLite default)
DATABASE_URL="file:./data/ats.db"
# For SQL Server instead, use:
# DATABASE_URL="sqlserver://HOST:1433;database=ats;user=sa;password=YourPassword;trustServerCertificate=true"

# JWT
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seed admin (only used on first `npm run seed`)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@123

# Microsoft Graph / Azure AD App Registration
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_DRIVE_ID=
MS_PARENT_FOLDER=Recruiters

# Background sync
SYNC_INTERVAL_MINUTES=15
