# Server
PORT=4000
NODE_ENV=production
# Comma-restrict this in production, e.g. http://localhost:8080
CORS_ORIGIN=*

# Database (SQLite default). docker-compose overrides this to /app/data/ats.db
DATABASE_URL="file:./data/ats.db"
# For SQL Server instead, use:
# DATABASE_URL="sqlserver://HOST:1433;database=ats;user=sa;password=YourPassword;trustServerCertificate=true"
# ...and change the `provider` in prisma/schema.prisma from "sqlite" to "sqlserver"

# JWT
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seed admin (only used the first time the server starts / `npm run seed` is run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@123

# Microsoft Graph / Azure AD App Registration - see README for setup steps
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_DRIVE_ID=
MS_PARENT_FOLDER=Recruiters

# Background sync interval, in minutes
SYNC_INTERVAL_MINUTES=15
